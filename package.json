{
  "name": "ornn-skills",
  "version": "0.1.10",
  "description": "Skill Evolution Agent - Background meta-agent for automatic skill optimization",
  "main": "dist/index.js",
  "bin": {
    "ornn": "dist/cli/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/cli/index.ts",
    "start": "node dist/cli/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:agent-poc": "tsx tests/agent-poc/run-all-tests.ts",
    "test:llm-config": "tsx tests/agent-poc/test-llm-config.ts",
    "test:evaluator": "tsx tests/agent-poc/test-evaluator-agent.ts",
    "test:patch-gen": "tsx tests/agent-poc/test-patch-generator.ts",
    "test:multi-model": "tsx tests/agent-poc/test-multi-model.ts",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "commit": "cz",
    "release": "standard-version",
    "release:first": "standard-version --first-release",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "prepare": "husky"
  },
  "keywords": [
    "skill",
    "evolution",
    "agent",
    "cli",
    "automation"
  ],
  "author": "OrnnSkills Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "commander": "^11.0.0",
    "cosmiconfig": "^8.3.0",
    "diff": "^5.1.0",
    "dotenv": "^16.4.5",
    "glob": "^13.0.0",
    "inquirer": "^13.3.2",
    "ora": "^7.0.0",
    "smol-toml": "^1.6.1",
    "sql.js": "^1.10.0",
    "toml": "^3.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/diff": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "commitizen": "^4.3.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.50.0",
    "husky": "^9.1.7",
    "prettier": "^3.0.0",
    "standard-version": "^9.5.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
