{
  "name": "ornn-skills",
  "version": "0.1.11",
  "description": "Skill Evolution Agent - Background meta-agent for automatic skill optimization",
  "main": "dist/index.js",
  "bin": {
    "ornn": "dist/cli/index.js"
  },
  "type": "module",
  "files": [
    "dist/",
    "README.md",
    "README.zh-CN.md",
    "CHANGELOG.md",
    "USER-GUIDE.md",
    "ARCHITECTURE.md",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc && npm run build:dashboard-v2 && npm run build:dashboard-v3 && npm run ensure:cli-exec",
    "build:dashboard-v2": "npm --prefix frontend install && npm --prefix frontend run build",
    "build:dashboard-v3": "npm --prefix frontend-v3 install && npm --prefix frontend-v3 run build",
    "dev": "tsx watch src/cli/index.ts",
    "dev:dashboard-v2": "npm --prefix frontend run dev",
    "dev:dashboard-v3": "npm --prefix frontend-v3 run dev",
    "start": "node dist/cli/index.js",
    "ensure:cli-exec": "sh -c 'if [ -f dist/cli/index.js ]; then chmod +x dist/cli/index.js; fi'",
    "prepack": "npm run build",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "benchmark": "npm run benchmark:dashboard",
    "benchmark:check": "npm run benchmark:dashboard:check",
    "benchmark:dashboard": "tsx scripts/benchmarks/dashboard-readers.ts",
    "benchmark:dashboard:check": "tsx scripts/benchmarks/dashboard-readers.ts --assert",
    "benchmark:dashboard:smoke": "tsx scripts/benchmarks/dashboard-readers.ts --dataset smoke",
    "benchmark:dashboard:soak": "tsx scripts/benchmarks/dashboard-soak.ts",
    "benchmark:dashboard:soak:check": "tsx scripts/benchmarks/dashboard-soak.ts --assert",
    "benchmark:dashboard:stress": "tsx scripts/benchmarks/dashboard-readers.ts --dataset stress",
    "test:agent-poc": "tsx tests/agent-poc/run-all-tests.ts",
    "test:llm-config": "tsx tests/agent-poc/test-llm-config.ts",
    "test:evaluator": "tsx tests/agent-poc/test-evaluator-agent.ts",
    "test:patch-gen": "tsx tests/agent-poc/test-patch-generator.ts",
    "test:multi-model": "tsx tests/agent-poc/test-multi-model.ts",
    "lint": "eslint src/ --ext .ts",
    "lint:fix": "eslint src/ --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "commit": "cz",
    "release": "standard-version",
    "release:first": "standard-version --first-release",
    "release:minor": "standard-version --release-as minor",
    "release:major": "standard-version --release-as major",
    "prepare": "husky && npm run ensure:cli-exec --if-present"
  },
  "keywords": [
    "skill",
    "evolution",
    "agent",
    "cli",
    "automation"
  ],
  "author": "OrnnSkills Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "chokidar": "^3.5.3",
    "commander": "^11.0.0",
    "cosmiconfig": "^8.3.0",
    "diff": "^5.1.0",
    "dotenv": "^16.4.5",
    "glob": "^13.0.0",
    "inquirer": "^13.3.2",
    "ora": "^7.0.0",
    "smol-toml": "^1.6.1",
    "sql.js": "^1.10.0",
    "toml": "^3.0.0",
    "uuid": "^13.0.0",
    "winston": "^3.11.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/diff": "^5.0.0",
    "@types/node": "^20.0.0",
    "@types/sql.js": "^1.4.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "commitizen": "^4.2.4",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^8.50.0",
    "husky": "^9.1.7",
    "prettier": "^3.0.0",
    "standard-version": "^9.5.0",
    "tinybench": "^6.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "overrides": {
    "commitizen": {
      "lodash": "^4.17.21",
      "tmp": "^0.2.3",
      "inquirer": {
        "external-editor": {
          "tmp": "^0.2.3"
        }
      }
    }
  }
}
