# OrnnSkills 环境变量配置
# 复制此文件为 .env.local 并填入你的 API Key

# ============================================
# LLM Provider API Keys
# ============================================

# DeepSeek (推荐 - 性价比高)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI
# 获取地址: https://platform.openai.com/
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (Claude)
# 获取地址: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Azure OpenAI (企业用户)
# AZURE_OPENAI_API_KEY=your-azure-api-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# AWS Bedrock (企业用户)
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_REGION=us-east-1

# Google Vertex AI (Gemini)
# GOOGLE_API_KEY=your-google-api-key

# Ollama (本地部署)
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# LangSmith 监控 (可选)
# ============================================
# 获取地址: https://smith.langchain.com/
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-langsmith-api-key
LANGCHAIN_PROJECT=ornn-skills

# ============================================
# LiteLLM Proxy (可选 - 企业部署)
# ============================================
# LITELLM_PROXY_BASE_URL=http://localhost:4000
# LITELLM_API_KEY=sk-your-litellm-proxy-key

# ============================================
# 开发调试
# ============================================
# DEBUG=true
# LOG_LEVEL=debug
